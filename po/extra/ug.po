#: data/terminal.metainfo.xml.in:10 data/io.elementary.terminal.desktop.in:2
#: data/io.elementary.terminal.desktop.in:3
msgid "Terminal"
msgstr "تېرمىنال"

#: data/terminal.metainfo.xml.in:11 data/io.elementary.terminal.desktop.in:4
msgid "Use the command line"
msgstr "كوماندا كۆرۈنمە يۈزىنى ئىشلىتىش"

#: data/terminal.metainfo.xml.in:13
msgid ""
"Terminal is a terminal emulator application for accessing a UNIX shell "
"environment which can be used to run programs available on your system."
msgstr ""
"بۇ تېرمىنال UNIX shell مۇھىتىنى زىيارەت قىلىش تەقلىدىي ئەپى بولۇپ، بۇ "
"تېرمىنال ئارقىلىق سىستېمىڭىزدا ئىجرا قىلغىلى بولىدىغان ئەپلەرنى ئىجرا "
"قىلالايسىز."

